# 복사해서 .env 로 사용 (실제 .env는 gitignore됨)
ENVIRONMENT=local

# Postgres — compose의 postgres 서비스와 값을 맞출 것
POSTGRES_USER=lede
POSTGRES_PASSWORD=lede
POSTGRES_DB=lede

# 앱이 읽는 접속 문자열 (async 드라이버). 컨테이너 내부 기준: postgres:5432
DATABASE_URL=postgresql+asyncpg://lede:lede@postgres:5432/lede
REDIS_URL=redis://redis:6379/0

# host(내 PC)에서 alembic 등을 직접 돌릴 때 — 공개 포트는 5433 (native PG 충돌 회피)
# DATABASE_URL=postgresql+asyncpg://lede:lede@localhost:5433/lede

# LLM — fake(비용 0) | anthropic(유료, 키 필요) | ollama(로컬, 무료)
LLM_PROVIDER=fake
CHARS_PER_MIN=500
# anthropic provider 사용 시:
ANTHROPIC_MODEL=claude-haiku-4-5
# ANTHROPIC_API_KEY는 시크릿 — .env에만 넣고 커밋 금지 (.env는 gitignore됨)
# ANTHROPIC_API_KEY=sk-ant-...
# ollama provider 사용 시 (먼저 `ollama pull exaone3.5:2.4b`):
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=exaone3.5:2.4b
# 컨테이너(worker)에서 host의 Ollama를 쓸 때:
# OLLAMA_BASE_URL=http://host.docker.internal:11434

# 이메일 / 다이제스트 — MVP 기본은 fake(실발송 0)
EMAIL_PROVIDER=fake
SEED_USER_EMAIL=siha@ssrinc.co.kr
DIGEST_TOP_N=5         # 점수 상위 N건만 다이제스트에 담음 (score>0)
